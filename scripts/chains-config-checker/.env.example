# Generic RPC endpoints (shared across multiple scripts)
# Mainnet
RPC_ETHEREUM="https://ethereum-rpc.publicnode.com"
RPC_GATEWAY="https://rpc.mainnet.zama.org"
RPC_BSC="https://bsc-dataseed.bnbchain.org"
RPC_HYPEREVM="https://rpc.hyperliquid.xyz/evm"
RPC_POLYGON="https://polygon-rpc.com"

# Testnet
RPC_SEPOLIA="https://ethereum-sepolia-rpc.publicnode.com"
RPC_GATEWAY_TESTNET="https://rpc.testnet.zama.org"
RPC_POLYGON_AMOY="https://rpc-amoy.polygon.technology"

# get-current-pausers.js — PauserSet contracts (mainnet: --mainnet, the default)
PAUSER_SET_ETHEREUM="0xbBfE1680b4a63ED05f7F80CE330BED7C992A586C"
PAUSER_SET_GATEWAY="0x571ecb596fCc5c840DA35CbeCA175580db50ac1b"
# PAUSER_SET_POLYGON=""  # set once the PauserSet is deployed on Polygon

# get-current-pausers.js — testnet PauserSet contracts (run with --testnet)
PAUSER_SET_SEPOLIA="0xc62392B4100a1bD45AbDBf91E70f1E4349402b46"
PAUSER_SET_GATEWAY_TESTNET="0x057dC9855536470A6D8C21d075bA17EA062A5dE7"
# PAUSER_SET_POLYGON_AMOY=""  # set once a PauserSet is deployed on Polygon Amoy

# Optional: pin each PauserSet's deployment block to skip archive-node deployment
# detection (binary search over eth_getCode at old blocks fails on pruned/public
# RPCs). Find the contract-creation block on the explorer and set it here. Without
# it, the script falls back to scanning events from block 0 (works on pruned nodes
# via eth_getLogs, just slower).
# PAUSER_SET_ETHEREUM_FROM_BLOCK=""
# PAUSER_SET_GATEWAY_FROM_BLOCK=""
# PAUSER_SET_POLYGON_FROM_BLOCK=""
PAUSER_SET_SEPOLIA_FROM_BLOCK="9766954"
# PAUSER_SET_GATEWAY_TESTNET_FROM_BLOCK=""
# PAUSER_SET_POLYGON_AMOY_FROM_BLOCK=""

