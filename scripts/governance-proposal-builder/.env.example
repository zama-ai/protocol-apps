# Destination chain RPCs (used by fill-options-remote-proposal to estimate
# lzReceive gas on the destination chain). The script falls back to the
# registry default in destinations.js when a var is unset, but using your own
# node is recommended. Destinations are defined in destinations.js
# (run `node destinations.js` to list them).
RPC_GATEWAY_MAINNET=https://rpc.mainnet.zama.org
RPC_GATEWAY_TESTNET=https://rpc-zama-testnet-0.t.conduit.xyz
# devnet governance is deployed on the Gateway testnet chain (same RPC as testnet)
RPC_GATEWAY_DEVNET=https://rpc-zama-testnet-0.t.conduit.xyz
RPC_POLYGON_AMOY_TESTNET=https://rpc-amoy.polygon.technology

# Ethereum L1 RPC (used by aragon-proposal-inspector).
RPC_ETHEREUM=https://eth.llamarpc.com

# Etherscan v2 API key (optional, used by aragon-proposal-inspector).
ETHERSCAN_API_KEY=
